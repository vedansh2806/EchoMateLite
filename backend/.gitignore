# ============================================================
# .gitignore for EchoMateLite Backend
# ============================================================

# ---- Environment Variables (NEVER push these to GitHub) ----
.env
.env.local
.env.production
.env.staging

# ---- Node Modules (auto-installed via npm install) ----
node_modules/
npm-debug.log*

# ---- Logs ----
logs/
*.log

# ---- OS Generated Files ----
.DS_Store
Thumbs.db

# ---- IDE / Editor Files ----
.vscode/
.idea/
*.swp
*.swo

# ---- Build Output ----
dist/
build/

# ---- Uploaded Files (temporary local storage before S3) ----
uploads/
